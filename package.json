{
  "name": "neurapath-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
    "deploy": "bun run build && bun run cf-typegen && wrangler deploy",
    "clean": "rm -rf .svelte-kit && rm -rf node_modules && rm -rf .wrangler && rm -rf .svelte-kit && rm -f bun.lock && rm -f package-lock.json && bun i"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/pdfjs-dist": "^2.10.378",
    "clsx": "^2.1.1",
    "layerchart": "^1.0.13",
    "mode-watcher": "^1.1.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@svelte-put/cloudflare-turnstile": "^1.2.0",
    "@tsndr/cloudflare-worker-jwt": "^3.2.1",
    "bcrypt-ts": "^8.0.1",
    "bits-ui": "^2.18.0",
    "pdfjs-dist": "^5.7.284",
    "posthog-js": "^1.372.5",
    "posthog-node": "^5.32.0",
    "quill": "^2.0.3"
  }
}
